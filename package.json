{
  "name": "mood-music",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:client & npm run dev:server",
    "dev:client": "npm run dev -w apps/client",
    "dev:server": "npm run dev -w apps/server",
    "build": "npm run build:client && npm run build:server",
    "build:client": "npm run build -w apps/client",
    "build:server": "npm run build -w apps/server",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.cjs --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,json,css,md}\"",
    "typecheck": "npm run typecheck:client && npm run typecheck:server",
    "typecheck:client": "npm run typecheck -w apps/client",
    "typecheck:server": "npm run typecheck -w apps/server",
    "test:client": "npm run test -w apps/client",
    "test:watch": "npm run test:watch -w apps/client",
    "test:server": "npm run test -w apps/server",
    "test:e2e": "npm run test:e2e -w apps/server"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@apps-in-toss/web-framework": "^2.5.0"
  }
}
